KNOWLEfrom __future__ import annotations

import os
from dataclasses import dataclass
from pathlib import Path

from dotenv import load_dotenv

load_dotenv()


@dataclass(slots=True)
class Settings:
    company_name: str = os.getenv('COMPANY_NAME', 'Demo Company')
    assistant_name: str = os.getenv('ASSISTANT_NAME', 'AI Callbot')
    base_url: str = os.getenv('BASE_URL', 'http://localhost:8000')
    port: int = int(os.getenv('PORT', '8000'))

    knowledge_dir: Path = Path(os.getenv('KNOWLEDGE_DIR', 'knowledge')).resolve()
    data_dir: Path = Path(os.getenv('DATA_DIR', 'data')).resolve()
    db_path: Path = Path(os.getenv('DB_PATH', 'data/callbot.db')).resolve()

    admin_api_key: str = os.getenv('ADMIN_API_KEY', 'change-me')

    twilio_voice: str = os.getenv('TWILIO_VOICE', 'alice')
    twilio_language: str = os.getenv('TWILIO_LANGUAGE', 'en-US')

    groq_api_key: str = os.getenv('GROQ_API_KEY', '')
    groq_model: str = os.getenv('GROQ_MODEL', 'llama-3.1-8b-instant')

    max_history_turns: int = int(os.getenv('MAX_HISTORY_TURNS', '6'))
    max_voice_chars: int = int(os.getenv('MAX_VOICE_CHARS', '900'))
    knowledge_top_k: int = int(os.getenv('KNOWLEDGE_TOP_K', '3'))
    knowledge_min_score: float = float(os.getenv('KNOWLEDGE_MIN_SCORE', '0.08'))

    def ensure_dirs(self) -> None:
        self.knowledge_dir.mkdir(parents=True, exist_ok=True)
        self.data_dir.mkdir(parents=True, exist_ok=True)
        self.db_path.parent.mkdir(parents=True, exist_ok=True)
